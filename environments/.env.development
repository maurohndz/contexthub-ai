# Template de variables de infraestructura para el ambiente DEVELOPMENT
# (servidor/entorno compartido, no el docker-compose local).
# Los valores reales viven en el gestor de secretos del ambiente; esto es
# solo la referencia de qué variables se necesitan.

POSTGRES_USER=contexthub
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=contexthub
POSTGRES_PORT=5432

REDIS_PASSWORD=CHANGE_ME
REDIS_PORT=6379
