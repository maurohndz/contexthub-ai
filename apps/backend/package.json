{
  "name": "@contexthub-ai/backend",
  "version": "0.1.0",
  "private": true,
  "main": "src/main.ts",
  "scripts": {
    "dev": "dotenv -e environments/.env.local -- tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "db:generate": "prisma generate",
    "db:migrate:local": "dotenv -e environments/.env.local -- prisma migrate dev",
    "db:studio:local": "dotenv -e environments/.env.local -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.5.0",
    "dotenv-cli": "^7.4.2",
    "prisma": "^6.9.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
