# Backend environment (see src/infrastructure/config/env.ts).
# The backend runs on the host (pnpm dev:backend) and reaches the infra
# containers via the ports published in the root environments/.env.local.

NODE_ENV=local
PORT=3000

# Must match POSTGRES_USER/PASSWORD/DB/PORT in the root environments/.env.local.
DATABASE_URL=postgresql://contexthub:contexthub_local_pw@localhost:5432/contexthub

# Frontend origin allowed to send the session cookie (comma-separated list).
CORS_ORIGIN=http://localhost:5173
COOKIE_SECURE=false

# Must match REDIS_PASSWORD/PORT in the root environments/.env.local.
REDIS_URL=redis://:contexthub_redis_pw@localhost:6379

# Embeddings: 'ollama' (local, free) or 'gemini' (needs GEMINI_API_KEY).
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768
OLLAMA_BASE_URL=http://localhost:11434

# Fallback API key used when an organization has not configured its own
# provider credential yet. Leave empty to force per-org configuration.
GEMINI_API_KEY=

# AES-256-GCM key for encrypting per-organization AI provider credentials.
# 32 bytes hex. Generated for this local environment with: openssl rand -hex 32
CREDENTIALS_ENCRYPTION_KEY=d74e1467d0a0a6ae32152d586669c41af72e8e1402fb2aecd632582fa9ad32e5

UPLOADS_DIR=./storage/uploads
